{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngrx-devtool": {
      "projectType": "library",
      "root": "projects/ngrx-devtool",
      "sourceRoot": "projects/ngrx-devtool/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/ngrx-devtool/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ngrx-devtool/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ngrx-devtool/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/ngrx-devtool/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngrx-devtool/**/*.ts",
              "projects/ngrx-devtool/**/*.html"
            ]
          }
        }
      }
    },
    "ngrx-devtool-demo": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/ngrx-devtool-demo",
      "sourceRoot": "projects/ngrx-devtool-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/ngrx-devtool-demo",
            "index": "projects/ngrx-devtool-demo/src/index.html",
            "browser": "projects/ngrx-devtool-demo/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/ngrx-devtool-demo/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/ngrx-devtool-demo/public"
              }
            ],
            "styles": ["projects/ngrx-devtool-demo/src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ngrx-devtool-demo:build:production"
            },
            "development": {
              "buildTarget": "ngrx-devtool-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "projects/ngrx-devtool-demo/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/ngrx-devtool-demo/public"
              }
            ],
            "styles": ["projects/ngrx-devtool-demo/src/styles.css"],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngrx-devtool-demo/**/*.ts",
              "projects/ngrx-devtool-demo/**/*.html"
            ]
          }
        }
      }
    },
    "ngrx-devtool-ui": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/ngrx-devtool-ui",
      "sourceRoot": "projects/ngrx-devtool-ui/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/ngrx-devtool-ui",
            "index": "projects/ngrx-devtool-ui/src/index.html",
            "browser": "projects/ngrx-devtool-ui/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/ngrx-devtool-ui/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/ngrx-devtool-ui/public"
              }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/azure-blue.css",
              "projects/ngrx-devtool-ui/src/styles.scss"
            ],
            "scripts": [],
            "server": "projects/ngrx-devtool-ui/src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "projects/ngrx-devtool-ui/src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "12kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ngrx-devtool-ui:build:production"
            },
            "development": {
              "buildTarget": "ngrx-devtool-ui:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "projects/ngrx-devtool-ui/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/ngrx-devtool-ui/public"
              }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/azure-blue.css",
              "projects/ngrx-devtool-ui/src/styles.css"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngrx-devtool-ui/**/*.ts",
              "projects/ngrx-devtool-ui/**/*.html"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
